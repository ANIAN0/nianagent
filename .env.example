# OpenAI-compatible Provider，仅服务端读取。
OPENAI_BASE_URL=https://<provider-endpoint>/v1
OPENAI_API_KEY=<provider-api-key>

# Next ↔ Agent Workflow 调试 bridge 内部密钥（浏览器永不持有）。
# 请换成足够长的随机串；两 Agent 与 Next 共用同一值。
NIANAGENT_WORKFLOW_DEBUG_SECRET=change-me-to-a-long-random-secret

# 工作区 Turso 库路径（Next 与两个 Agent 必须指向同一文件）。
# 默认解析为 nianagent/.workflow-data/nianagent.db；Agent 打包运行时强烈建议显式设置绝对路径。
# NIANAGENT_WORKSPACE_DB=H:\path\to\nianagent\.workflow-data\nianagent.db

# 可选：PowerShell 7 可执行文件绝对路径。
# 默认按序探测：NIANAGENT_PWSH → %ProgramFiles%\PowerShell\7\pwsh.exe → PATH 中的 pwsh。
# 绑定 UI 与 POST /api/workspace-bindings 会 fail-closed 预检；禁止 5.1 / Git Bash 回退。
# NIANAGENT_PWSH=C:\Program Files\PowerShell\7\pwsh.exe
