{
  "name": "nianagent",
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*",
    "#evals/*": "./evals/*"
  },
  "scripts": {
    "build": "pnpm run build:eve && next build",
    "dev": "next dev -H 127.0.0.1",
    "start": "concurrently --kill-others --names knowledge-base,work-assistant,web \"pnpm start:eve:knowledge-base\" \"pnpm start:eve:work-assistant\" \"pnpm start:web\"",
    "start:web": "wait-on --timeout 30000 http-get://127.0.0.1:4274/eve/v1/health http-get://127.0.0.1:4275/eve/v1/health && next start -H 127.0.0.1",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:eve": "pnpm --dir agents/knowledge-base build && pnpm --dir agents/work-assistant build",
    "dev:eve:knowledge-base": "pnpm --dir agents/knowledge-base exec eve dev --host 127.0.0.1 --port 4274",
    "dev:eve:work-assistant": "pnpm --dir agents/work-assistant exec eve dev --host 127.0.0.1 --port 4275",
    "start:eve:knowledge-base": "dotenv -e .env -- pnpm --dir agents/knowledge-base exec eve start --host 127.0.0.1 --port 4274",
    "start:eve:work-assistant": "dotenv -e .env -- pnpm --dir agents/work-assistant exec eve start --host 127.0.0.1 --port 4275"
  },
  "dependencies": {
    "@nianagent/agent-core": "workspace:*",
    "@radix-ui/react-use-controllable-state": "1.2.2",
    "@shikijs/core": "4.1.0",
    "@shikijs/engine-javascript": "4.1.0",
    "@shikijs/engine-oniguruma": "4.1.0",
    "@streamdown/cjk": "1.0.3",
    "@streamdown/code": "1.1.1",
    "@streamdown/math": "1.0.2",
    "@streamdown/mermaid": "1.0.2",
    "@tailwindcss/postcss": "4.3.0",
    "@vercel/connect": "0.2.2",
    "ai": "^7.0.26",
    "cbor-x": "^1.6.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "eve": "^0.24.4",
    "lucide-react": "1.16.0",
    "motion": "12.40.0",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shiki": "4.1.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.0",
    "use-stick-to-bottom": "1.1.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.x",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "typescript": "6.0.3",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "ai": "^7.0.26"
  },
  "engines": {
    "node": "24.x"
  },
  "optionalDependencies": {
    "@tursodatabase/database-win32-x64-msvc": "0.4.4"
  }
}
